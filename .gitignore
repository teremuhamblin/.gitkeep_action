########################################
# 🔒 Dossiers versionnés uniquement via .gitkeep
########################################

logs/*
!logs/.gitkeep

cache/*
!cache/.gitkeep

tmp/*
!tmp/.gitkeep

data/*
!data/.gitkeep

########################################
# 📝 Logs
########################################

*.log

########################################
# 🐍 Python
########################################

__pycache__/
*.pyc
*.pyo
*.pyd

# Environnements
.env
.env.local
.env.*.local

########################################
# 🟦 Node / JavaScript
########################################

node_modules/
npm-debug.log
yarn-error.log

########################################
# 💻 OS files
########################################

.DS_Store
Thumbs.db

########################################
# 🛠️ IDE / Éditeurs
########################################

.vscode/
.idea/

########################################
# 🏗️ Build / Distribution
########################################

dist/
build/

########################################
# 🧪 Tests
########################################

coverage/
